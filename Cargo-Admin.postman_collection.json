    {
      "name": "04 - Customer Auth",
      "item": [
        {
          "name": "Register - Send OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Registration OTP response is successful', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json?.data?.otp) pm.collectionVariables.set('register_otp', json.data.otp);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept-Language", "value": "{{locale}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"{{phone_number}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/register/otp/send",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "register", "otp", "send"]
            }
          },
          "response": []
        },
        {
          "name": "Register - Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept-Language", "value": "{{locale}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"{{phone_number}}\",\n  \"otp\": \"{{register_otp}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/register/otp/verify",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "register", "otp", "verify"]
            }
          },
          "response": []
        },
        {
          "name": "Register - Complete",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.collectionVariables.set('customer_token', json.data.token);",
                  "if (json?.data?.customer?.id) pm.collectionVariables.set('customer_id', json.data.customer.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Accept-Language", "value": "{{locale}}", "type": "text" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "full_name", "value": "{{full_name}}", "type": "text" },
                { "key": "phone_number", "value": "{{phone_number}}", "type": "text" },
                { "key": "email", "value": "{{email}}", "type": "text" },
                { "key": "password", "value": "{{password}}", "type": "text" },
                { "key": "password_confirmation", "value": "{{password}}", "type": "text" },
                { "key": "device_name", "value": "{{device_name}}", "type": "text" },
                { "key": "device_token", "value": "{{device_token}}", "type": "text" },
                { "key": "profile_photo", "type": "file", "src": [], "disabled": true }
              ]
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/register/complete",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "register", "complete"]
            }
          },
          "response": []
        },
        {
          "name": "Login - Send OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login OTP response is successful', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
