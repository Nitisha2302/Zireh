                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept-Language", "value": "{{locale}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"{{phone_number}}\",\n  \"otp\": \"{{login_otp}}\",\n  \"device_name\": \"{{device_name}}\",\n  \"device_token\": \"{{device_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/login/otp/verify",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "login", "otp", "verify"]
            }
          },
          "response": []
        },
        {
          "name": "OTP - Resend",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept-Language", "value": "{{locale}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"{{phone_number}}\",\n  \"purpose\": \"login\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/otp/resend",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "otp", "resend"]
            }
          },
          "response": []
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.warehouse_id) pm.collectionVariables.set('warehouse_id', json.data.warehouse_id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{customer_token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "type": "text" },
              { "key": "Accept-Language", "value": "{{locale}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "me"]
            }
          },
          "response": []
        },
